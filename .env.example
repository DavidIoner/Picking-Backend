# ==========================================
# PostgreSQL Configuration
# ==========================================
POSTGRES_DB=cnh_metodologia_picking
POSTGRES_USER=cnh_user
POSTGRES_PASSWORD=cnh_password_2025

# ==========================================
# API Configuration
# ==========================================
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:8080

# Connection String
# Formato: Server=host;Database=nome;User Id=usuario;Password=senha;
CONNECTION_STRING=Server=postgres;Database=cnh_metodologia_picking;User Id=cnh_user;Password=cnh_password_2025;

# ==========================================
# Ports
# ==========================================
API_PORT=8080
POSTGRES_PORT=5432

# ==========================================
# Network
# ==========================================
NETWORK_NAME=cnh-network

